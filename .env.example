# .env.example - Copy this to .env.local and fill in your actual values
# NEVER commit your .env.local file

# ============================================
# AI / ANTHROPIC
# ============================================
ANTHROPIC_API_KEY=sk-your-anthropic-key-here

# ============================================
# DATABASE - CHOREQUEST (HOME MODE)
# ============================================
# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@db.neon.tech/chorequest?sslmode=require
PRISMA_DATABASE_URL=${DATABASE_URL}

# ============================================
# DATABASE - PTO CONNECT (ORG MODE)
# ============================================
# Supabase PostgreSQL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# AUTHENTICATION - CLERK
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================
# SMS / REMINDERS - TWILIO
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# EMAIL - SENDGRID
# ============================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@chorequest-pto.com

# ============================================
# PAYMENTS / FUNDRAISING - STRIPE
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# MCP SERVERS (Local Development)
# ============================================
MCP_TASK_COORDINATION_URL=http://localhost:5001
MCP_ENGAGEMENT_REWARDS_URL=http://localhost:5002
MCP_COMMUNICATION_URL=http://localhost:5003
MCP_INSIGHTS_ANALYTICS_URL=http://localhost:5004

# ============================================
# AGENT CONFIGURATION
# ============================================
AGENT_LOG_LEVEL=info
AGENT_MAX_TOKENS=2000
AGENT_TEMPERATURE=0.7
AGENT_CONTEXT_LENGTH=4096

# ============================================
# DEPLOYMENT / ENVIRONMENT
# ============================================
NODE_ENV=development
VERCEL_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=debug
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AGENT_NOTIFICATIONS=true
ENABLE_SMS_REMINDERS=false  # Set to true only in production
ENABLE_EMAIL_DIGESTS=false  # Set to true only in production
ENABLE_ANALYTICS=true
